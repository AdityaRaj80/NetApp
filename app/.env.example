# Kafka
KAFKA_BOOTSTRAP=netapp-kafka:29092
KAFKA_TOPIC=sensor_stream
KAFKA_GROUP=netapp-consumer

# API
STREAM_API=http://stream-api:8001
API_PORT=8001

# Dashboard
DASHBOARD_PORT=8601

# Policy thresholds
TEMP_ALERT=80
HOT_MSG_THRESHOLD=20
COLD_IDLE_MINUTES=10

# ML
ANOMALY_Z_THRESH=3.0
USE_ISOFOREST=false
